# =============================================================================
# ProInvestAI — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control!
# =============================================================================

# --- Core Settings ---
APP_NAME=ProInvestAI
DEBUG=True

# --- Database ---
# Local development (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./proinvestai.db
# Docker development (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://postgres:YOUR_STRONG_PASSWORD@db:5432/proinvestai
# Production (set via hosting platform):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE-ME-BEFORE-DEPLOY

# --- Docker Compose (PostgreSQL) ---
POSTGRES_DB=proinvestai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE-ME-USE-STRONG-PASSWORD

# --- External APIs ---
GEMINI_API_KEY=your_gemini_api_key_here
MERCADOPAGO_ACCESS_TOKEN=your_mp_token_here
BRAPI_TOKEN=your_brapi_token_here
BCB_API_URL=https://api.bcb.gov.br/dados/serie/bcdata.sgs
